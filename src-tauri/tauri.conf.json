{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Octave",
  "version": "0.5.0",
  "identifier": "com.octave.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Octave",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "../src-python/main"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["English"],
        "installMode": "perMachine",
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/128x128.png",
        "sidebarImage": "icons/128x128@2x.png",
        "minimumWebview2Version": "2.0.0"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": []
      },
      "rpm": {
        "epoch": 0
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["octave"]
      }
    },
    "updater": {
      "active": false,
      "pubkey": "",
      "endpoints": ["https://releases.octave.app/{{target}}/{{arch}}/{{current_version}}"]
    }
  }
}
